    },
    {
      "src": "/static/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable any"
    }
  ],
  "shortcuts": [
    {
      "name": "AgroStore",
      "short_name": "Store",
      "description": "Buy farming inputs and equipment",
      "url": "/store/",
      "icons": [
        {
          "src": "/static/icons/store-icon-96x96.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Market Intelligence",
      "short_name": "Market",
      "description": "AI-powered crop price predictions",
      "url": "/#market-intelligence",
      "icons": [
        {
          "src": "/static/icons/market-icon-96x96.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Crop Scanner",
      "short_name": "Scanner",
      "description": "AI crop quality analysis",
      "url": "/#crop-scanner",
      "icons": [
        {
          "src": "/static/icons/scanner-icon-96x96.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "screenshots": [
    {
      "src": "/static/screenshots/home-desktop.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "AgroSense Dashboard - Desktop View"
    },
    {
      "src": "/static/screenshots/home-mobile.png",
      "sizes": "375x667",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "AgroSense Dashboard - Mobile View"
    },
    {
      "src": "/static/screenshots/store-mobile.png",
      "sizes": "375x667",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "AgroStore - Mobile Shopping Experience"
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "edge_side_panel": {
    "preferred_width": 400
  },
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "protocol_handlers": [
    {
      "protocol": "web+agrosense",
      "url": "/handle-protocol?url=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/handle-crop-image",
      "accept": {
        "image/jpeg": [".jpg", ".jpeg"],
        "image/png": [".png"],
        "image/webp": [".webp"]
      }
    }
  ],
  "share_target": {
    "action": "/share-crop-data",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "crop_image",
          "accept": ["image/jpeg", "image/png", "image/webp"]
        }
      ]
    }
  }
}
